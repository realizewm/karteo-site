# Resend — envio de emails do lead magnet (calculadora do Assessor)
# 1) Crie sua conta em https://resend.com/
# 2) Gere uma API key em https://resend.com/api-keys
# 3) Copie esse arquivo para .env e preencha os valores reais

# Sua API key do Resend (obrigatório pro endpoint funcionar)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Remetente "FROM" do email — precisa ser um domínio verificado no Resend
# (Pra testes iniciais, pode usar o sandbox: "Karteo <onboarding@resend.dev>")
RESEND_FROM_EMAIL=Karteo <hello@karteo.com.br>

# Email opcional pra receber notificação de cada lead capturado
# (você recebe uma cópia toda vez que alguém preenche a calculadora e pede o relatório)
RESEND_NOTIFY_EMAIL=joaocabral@outlook.com

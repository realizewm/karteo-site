<script>
  const PROFILES = ['planejador', 'consultor', 'assessor', 'outro'] as const;
  type Profile = typeof PROFILES[number];
  const KEY = 'karteo:profile';

  // Prioridade: URL ?perfil=X (campanha) > localStorage > default
  const urlPerfil = new URLSearchParams(window.location.search).get('perfil');
  const stored = localStorage.getItem(KEY);

  let initial: Profile = 'planejador';
  if (urlPerfil && (PROFILES as readonly string[]).includes(urlPerfil)) {
    initial = urlPerfil as Profile;
    localStorage.setItem(KEY, initial); // persiste pra próxima visita
  } else if (stored && (PROFILES as readonly string[]).includes(stored)) {
    initial = stored as Profile;
  }
  document.body.dataset.profile = initial;

  const buttons = document.querySelectorAll<HTMLButtonElement>('[data-profile-toggle]');
  const sync = (active: Profile) => {
    buttons.forEach(b =>
      b.setAttribute('aria-checked', b.dataset.profileToggle === active ? 'true' : 'false')
    );
  };
  sync(initial);

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const p = btn.dataset.profileToggle as Profile | undefined;
      if (!p || !(PROFILES as readonly string[]).includes(p)) return;
      document.body.dataset.profile = p;
      localStorage.setItem(KEY, p);
      sync(p);
    });
  });
</script>

<script>
  const fmtBRL = (n: number) =>
    n.toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

  const HORAS_AXION = 1.5; // tempo médio real: 1h30 por planejamento com Karteo
  const CALC_KEY = 'karteo:calc';

  type CalcState = { ticket: number; horas: number; planos: number };

  const elTicket = document.getElementById('calc-ticket') as HTMLInputElement | null;
  const elHoras = document.getElementById('calc-horas') as HTMLInputElement | null;
  const elPlanos = document.getElementById('calc-planos') as HTMLInputElement | null;

  const elAumentoTicket = document.getElementById('calc-aumento-ticket') as HTMLInputElement | null;
  const elAumentoTicketValue = document.getElementById('calc-aumento-ticket-value');

  // Passo 1 — Tempo (HOJE vs COM AXION + DELTA)
  const elDiasHoje = document.getElementById('calc-out-dias-hoje');
  const elHorasHoje = document.getElementById('calc-out-horas-hoje');
  const elDiasKarteo = document.getElementById('calc-out-dias-karteo');
  const elHorasKarteoTempo = document.getElementById('calc-out-horas-karteo-tempo');
  const elDiasRecuperados = document.getElementById('calc-out-dias-recuperados');
  const elSemanasRecuperadas = document.getElementById('calc-out-semanas-recuperadas');

  // Passo 2 — Hora (HOJE vs COM AXION + MULT)
  const elHoraHoje = document.getElementById('calc-out-hora-hoje');
  const elHoraKarteo = document.getElementById('calc-out-hora-karteo');
  const elMult = document.getElementById('calc-out-mult');

  // Passo 4 — Receita (HOJE vs COM AXION + SOBRA LÍQUIDA)
  const elReceitaHoje = document.getElementById('calc-out-receita-hoje');
  const elReceitaPotencial = document.getElementById('calc-out-receita-potencial');
  const elDeltaReceita = document.getElementById('calc-out-delta-receita');
  const elSobraDetalhe = document.getElementById('calc-out-sobra-detalhe');

  const elDiag = document.getElementById('calc-out-diag');

  const CUSTO_AXION_PRO = 5964;

  const parseBR = (s: string) => Number(s.replace(/\./g, '').replace(',', '.')) || 0;
  const formatBRInt = (n: number) => Math.floor(n).toLocaleString('pt-BR');
  const formatLiveBR = (el: HTMLInputElement) => {
    const raw = el.value.replace(/\D/g, '');
    el.value = raw ? Number(raw).toLocaleString('pt-BR') : '';
  };

  if (
    elTicket && elHoras && elPlanos && elAumentoTicket && elAumentoTicketValue &&
    elDiasHoje && elHorasHoje && elDiasKarteo && elHorasKarteoTempo &&
    elDiasRecuperados && elSemanasRecuperadas &&
    elHoraHoje && elHoraKarteo && elMult &&
    elReceitaHoje && elReceitaPotencial && elDeltaReceita && elSobraDetalhe && elDiag
  ) {
    const stored = localStorage.getItem(CALC_KEY);
    if (stored) {
      try {
        const s = JSON.parse(stored) as CalcState;
        if (typeof s.ticket === 'number' && s.ticket > 0) elTicket.value = formatBRInt(s.ticket);
        if (typeof s.horas === 'number' && s.horas > 0) elHoras.value = String(s.horas);
        if (typeof s.planos === 'number' && s.planos > 0) elPlanos.value = String(s.planos);
        if (typeof (s as { aumentoTicket?: number }).aumentoTicket === 'number') {
          elAumentoTicket.value = String((s as { aumentoTicket: number }).aumentoTicket);
        }
      } catch {}
    }

    // Formata ao vivo enquanto digita (pontos de milhar)
    elTicket.addEventListener('input', () => formatLiveBR(elTicket));

    const recalc = () => {
      const ticket = Math.max(1, parseBR(elTicket.value));
      const horas = Math.max(1, Number(elHoras.value) || 1);
      const planos = Math.max(1, Number(elPlanos.value) || 1);
      const aumentoTicketPct = Math.max(0, Math.min(100, Number(elAumentoTicket.value) || 0));
      const aumento = aumentoTicketPct / 100;

      elAumentoTicketValue.textContent = String(aumentoTicketPct);

      // PASSO 1 — TEMPO
      const horasHojeAno = horas * planos * 12;
      const horasKarteoAno = HORAS_AXION * planos * 12;
      const diasHojeAno = Math.round(horasHojeAno / 8);
      const diasKarteoAno = Math.round(horasKarteoAno / 8);
      const diasRecuperados = Math.max(0, diasHojeAno - diasKarteoAno);
      const semanasRecuperadas = Math.round(diasRecuperados / 5);

      elDiasHoje.textContent = `${diasHojeAno} dias/ano`;
      elHorasHoje.textContent = `${formatBRInt(horasHojeAno)}h/ano`;
      elDiasKarteo.textContent = `${diasKarteoAno} dias/ano`;
      elHorasKarteoTempo.textContent = `${formatBRInt(horasKarteoAno)}h/ano`;
      elDiasRecuperados.textContent = `${diasRecuperados} dias úteis/ano`;
      elSemanasRecuperadas.textContent = `(≈${semanasRecuperadas} semanas livres)`;

      // PASSO 2 — VALOR DA HORA
      const horaHoje = ticket / horas;
      const horaKarteo = ticket / HORAS_AXION;
      const mult = horaKarteo / horaHoje;

      elHoraHoje.textContent = `R$ ${fmtBRL(horaHoje)}`;
      elHoraKarteo.textContent = `R$ ${fmtBRL(horaKarteo)}`;
      elMult.textContent = `${mult.toFixed(1).replace('.', ',')}×`;

      // PASSO 4 — RECEITA (HOJE vs COM AXION + SOBRA LÍQUIDA já descontado o Karteo)
      const receitaHojeAno = ticket * planos * 12;
      const receitaPotencialAno = ticket * (1 + aumento) * planos * 12;
      const deltaReceita = receitaPotencialAno - receitaHojeAno;
      const sobraLiquida = deltaReceita - CUSTO_AXION_PRO;

      elReceitaHoje.textContent = `R$ ${formatBRInt(receitaHojeAno)}`;
      elReceitaPotencial.textContent = `R$ ${formatBRInt(receitaPotencialAno)}`;

      if (sobraLiquida > 0) {
        elDeltaReceita.textContent = `+ R$ ${formatBRInt(sobraLiquida)}`;
        elSobraDetalhe.textContent = 'já descontado Karteo';
      } else if (deltaReceita > 0) {
        // gera receita extra mas não cobre o Karteo ainda
        elDeltaReceita.textContent = `R$ ${formatBRInt(Math.abs(sobraLiquida))}`;
        elSobraDetalhe.textContent = 'falta p/ pagar Karteo';
      } else {
        elDeltaReceita.textContent = `R$ 0`;
        elSobraDetalhe.textContent = 'aumente o ticket no slider';
      }

      // DIAGNÓSTICO — número líquido (zero subtração mental)
      const roiLiquido = sobraLiquida > 0 ? (sobraLiquida / CUSTO_AXION_PRO) : 0;
      if (sobraLiquida > 0) {
        elDiag.innerHTML = `<strong>+ R$ ${formatBRInt(sobraLiquida)} limpos</strong> no seu bolso (já descontado o Karteo) <em>e</em> <strong>${diasRecuperados} dias úteis</strong> de volta no calendário. ROI <strong>${roiLiquido.toFixed(1).replace('.', ',')}×</strong> só em dinheiro — o tempo é bônus.`;
      } else if (deltaReceita > 0) {
        elDiag.innerHTML = `Você ganha <strong>+ R$ ${formatBRInt(deltaReceita)}</strong> em receita extra, mas ainda <strong>R$ ${formatBRInt(Math.abs(sobraLiquida))}</strong> abaixo do custo do Karteo. Aumente o slider de ticket — ou ganhe pelo menos no <strong>tempo</strong>: ${diasRecuperados} dias úteis/ano de volta.`;
      } else {
        elDiag.innerHTML = `Sem aumento de ticket, o ganho é <strong>tempo puro</strong>: <strong>${diasRecuperados} dias úteis/ano</strong> de volta e sua hora passa a valer <strong>${mult.toFixed(1).replace('.', ',')}×</strong> mais. Mexa no slider acima pra ver quanto sobra no bolso quando você cobra mais caro.`;
      }

      localStorage.setItem(CALC_KEY, JSON.stringify({ ticket, horas, planos, aumentoTicket: aumentoTicketPct }));
    };

    [elTicket, elHoras, elPlanos, elAumentoTicket].forEach(el =>
      el.addEventListener('input', recalc)
    );

    recalc();
  }
</script>

<script>
  // Calculadora de Churn — perfil Assessor
  const fmtBRLChurn = (n: number) =>
    n.toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

  const REDUCAO_CHURN_DEFAULT = 0.30; // default ajustado pelo operador (mercado); lead controla via slider (10-50%)
  const CUSTO_AXION_PRO_ANO = 5964; // R$ 497 × 12
  const CHURN_KEY = 'karteo:calc-churn';

  type ChurnState = {
    aumTotal: number;
    clientes: number;
    roa: number;
    churn: number;
    repasse: number;
    reducao: number;
  };

  const elAum = document.getElementById('calc-aum') as HTMLInputElement | null;
  const elRoa = document.getElementById('calc-roa') as HTMLInputElement | null;
  const elClientes = document.getElementById('calc-clientes') as HTMLInputElement | null;
  const elChurnPct = document.getElementById('calc-churn-pct') as HTMLInputElement | null;
  const elRepasse = document.getElementById('calc-repasse') as HTMLInputElement | null;
  const elReducao = document.getElementById('calc-reducao') as HTMLInputElement | null;
  const elReducaoValue = document.getElementById('calc-reducao-value');
  const elReducaoLabel = document.getElementById('calc-out-reducao-label');

  const elEmptyState = document.getElementById('calc-empty-state');
  const elContent = document.getElementById('calc-content');
  const elPerda = document.getElementById('calc-out-perda');
  const elProtegida = document.getElementById('calc-out-protegida');
  const elSobra = document.getElementById('calc-out-sobra');
  const elDiagChurn = document.getElementById('calc-out-diag-churn');

  const parseBRChurn = (s: string) => Number(s.replace(/\./g, '').replace(',', '.')) || 0;
  const formatBRIntChurn = (n: number) => Math.floor(n).toLocaleString('pt-BR');
  const formatLiveBRChurn = (el: HTMLInputElement) => {
    const raw = el.value.replace(/\D/g, '');
    el.value = raw ? Number(raw).toLocaleString('pt-BR') : '';
  };

  if (
    elAum && elRoa && elClientes && elChurnPct && elRepasse && elReducao &&
    elReducaoValue && elReducaoLabel &&
    elEmptyState && elContent && elPerda && elProtegida && elSobra && elDiagChurn
  ) {
    const storedChurn = localStorage.getItem(CHURN_KEY);
    if (storedChurn) {
      try {
        const s = JSON.parse(storedChurn) as ChurnState;
        if (typeof s.aumTotal === 'number' && s.aumTotal > 0) elAum.value = formatBRIntChurn(s.aumTotal);
        if (typeof s.clientes === 'number' && s.clientes > 0) elClientes.value = String(s.clientes);
        if (typeof s.roa === 'number' && s.roa > 0) elRoa.value = String(s.roa);
        if (typeof s.churn === 'number' && s.churn > 0) elChurnPct.value = String(s.churn);
        if (typeof s.repasse === 'number' && s.repasse > 0) elRepasse.value = String(s.repasse);
        if (typeof s.reducao === 'number' && s.reducao > 0) elReducao.value = String(s.reducao);
      } catch {}
    }

    // Formata ao vivo enquanto digita (pontos de milhar)
    elAum.addEventListener('input', () => formatLiveBRChurn(elAum));

    const recalcChurn = () => {
      const aumTotal = parseBRChurn(elAum.value);
      const clientes = Number(elClientes.value) || 0;
      const roa = Math.max(0.01, Number(elRoa.value) || 0) / 100;
      const churn = Math.max(0.01, Number(elChurnPct.value) || 0) / 100;
      const repasse = Math.max(0.01, Number(elRepasse.value) || 0) / 100;
      const reducaoPct = Math.max(1, Math.min(60, Number(elReducao.value) || 30));
      const reducao = reducaoPct / 100;

      // Reflete o valor do slider na UI (input + output)
      elReducaoValue.textContent = String(reducaoPct);
      elReducaoLabel.textContent = `${reducaoPct}%`;

      // Estado vazio quando faltar AUM total ou clientes
      const leadWrap = document.getElementById('calc-churn-lead');
      if (aumTotal <= 0 || clientes <= 0) {
        elEmptyState.style.display = 'flex';
        elContent.style.display = 'none';
        if (leadWrap) leadWrap.style.visibility = 'hidden';
        return;
      }
      elEmptyState.style.display = 'none';
      elContent.style.display = 'block';
      if (leadWrap) leadWrap.style.visibility = 'visible';

      const receitaBrutaAno = aumTotal * roa;
      const receitaLiquidaAno = receitaBrutaAno * repasse;
      const perdaLiquidaAno = receitaLiquidaAno * churn;
      const protegidaAno = perdaLiquidaAno * reducao;
      const sobraAno = protegidaAno - CUSTO_AXION_PRO_ANO;

      elPerda.textContent = `R$ ${fmtBRLChurn(perdaLiquidaAno)}`;
      elProtegida.textContent = `R$ ${fmtBRLChurn(protegidaAno)}`;
      elSobra.textContent = sobraAno >= 0
        ? `R$ ${fmtBRLChurn(sobraAno)}`
        : `−R$ ${fmtBRLChurn(Math.abs(sobraAno))}`;

      if (sobraAno >= 0) {
        elDiagChurn.innerHTML = `Cliente que fica paga sua mensalidade do Karteo <strong>e ainda sobra R$ ${fmtBRLChurn(sobraAno)} no seu bolso</strong>. Quanto maior sua carteira, maior esse número.`;
      } else {
        elDiagChurn.innerHTML = `Sua carteira ainda não fecha o ROI direto via churn. Mas o Karteo vira <strong>diferencial competitivo na captação</strong> — material profissional fecha cliente novo, e o ROI vira positivo na próxima dezena de clientes.`;
      }

      localStorage.setItem(CHURN_KEY, JSON.stringify({
        aumTotal, clientes,
        roa: roa * 100, churn: churn * 100, repasse: repasse * 100,
        reducao: reducaoPct,
      }));
    };

    [elAum, elRoa, elClientes, elChurnPct, elRepasse, elReducao].forEach(el =>
      el.addEventListener('input', recalcChurn)
    );

    recalcChurn();
  }
</script>

<script>
  // Lead magnet — captura email do assessor após o cálculo
  const leadForm = document.getElementById('lead-form') as HTMLFormElement | null;
  const leadFormState = document.getElementById('lead-form-state');
  const leadSuccessState = document.getElementById('lead-success-state');
  const leadSubmit = document.getElementById('lead-submit') as HTMLButtonElement | null;
  const leadNome = document.getElementById('lead-nome') as HTMLInputElement | null;
  const leadEmail = document.getElementById('lead-email') as HTMLInputElement | null;

  if (leadForm && leadFormState && leadSuccessState && leadSubmit && leadNome && leadEmail) {
    leadForm.addEventListener('submit', async (e) => {
      e.preventDefault();

      const nome = leadNome.value.trim();
      const email = leadEmail.value.trim();

      // Validação local COM feedback visível (antes era um return silencioso — parecia que o site quebrava)
      const showLeadError = (msg: string) => {
        leadForm.querySelector('[data-lead-error]')?.remove();
        const el = document.createElement('p');
        el.dataset.leadError = 'true';
        el.className = 'mt-2 text-center text-[11px] text-error';
        el.textContent = msg;
        leadForm.appendChild(el);
      };

      if (!nome || !email || !email.includes('@')) {
        showLeadError(!nome
          ? 'Preencha seu nome, por favor.'
          : 'Digite um email válido (ex.: nome@email.com).');
        return;
      }
      leadForm.querySelector('[data-lead-error]')?.remove();

      leadSubmit.disabled = true;
      leadSubmit.textContent = 'Enviando...';

      // Snapshot dos dados da calculadora pra mandar junto no payload
      const aumInput = document.getElementById('calc-aum') as HTMLInputElement | null;
      const clientesInput = document.getElementById('calc-clientes') as HTMLInputElement | null;
      const roaInput = document.getElementById('calc-roa') as HTMLInputElement | null;
      const churnInput = document.getElementById('calc-churn-pct') as HTMLInputElement | null;
      const repasseInput = document.getElementById('calc-repasse') as HTMLInputElement | null;
      const reducaoInput = document.getElementById('calc-reducao') as HTMLInputElement | null;
      const perdaTxt = document.getElementById('calc-out-perda')?.textContent ?? '';
      const protegidaTxt = document.getElementById('calc-out-protegida')?.textContent ?? '';
      const sobraTxt = document.getElementById('calc-out-sobra')?.textContent ?? '';

      const payload = {
        nome,
        email,
        perfil: 'assessor',
        aumTotal: aumInput?.value ?? '',
        clientes: clientesInput?.value ?? '',
        roa: roaInput?.value ?? '',
        churn: churnInput?.value ?? '',
        repasse: repasseInput?.value ?? '',
        reducao: reducaoInput?.value ?? '30',
        diagnostico: { perda: perdaTxt, protegida: protegidaTxt, sobra: sobraTxt },
        capturadoEm: new Date().toISOString(),
      };

      try {
        const res = await fetch('/api/lead-churn', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const data = (await res.json().catch(() => ({}))) as { ok?: boolean; error?: string };

        if (!res.ok || !data.ok) {
          throw new Error(data.error ?? 'Falha ao enviar email');
        }

        leadFormState.style.display = 'none';
        leadSuccessState.style.display = 'block';
      } catch (err) {
        console.error('[lead-churn] erro:', err);
        leadSubmit.disabled = false;
        leadSubmit.textContent = 'Tentar novamente';
        const existingError = leadForm.querySelector('[data-lead-error]');
        if (existingError) existingError.remove();
        const errEl = document.createElement('p');
        errEl.dataset.leadError = 'true';
        errEl.className = 'mt-2 text-center text-[11px] text-error';
        errEl.textContent = 'Não conseguimos enviar agora. Tente em alguns instantes ou escreva para joao@karteo.com.br.';
        leadForm.appendChild(errEl);
      }
    });
  }
</script>

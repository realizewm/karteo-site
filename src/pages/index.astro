  <script>
    (function () {
      const car = document.getElementById('virada-carousel');
      if (!car) return;
      const slides = Array.from(car.querySelectorAll('.vc-slide'));
      const dots = Array.from(car.querySelectorAll('.vc-dot'));
      const fills = Array.from(car.querySelectorAll('.vc-fill'));
      const DURATION = 5000;
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      let active = 0, elapsed = 0, last = null, paused = false;

      // Fonte de tempo ÚNICA (elapsed): a barrinha e a troca compartilham o mesmo
      // cronômetro, então a barra completa EXATAMENTE no instante da troca, sempre igual.
      function apply() {
        slides.forEach((s, i) => {
          s.classList.toggle('opacity-100', i === active);
          s.classList.toggle('opacity-0', i !== active);
        });
        fills.forEach((f, i) => {
          f.style.width = (i < active ? 100 : i > active ? 0 : (elapsed / DURATION) * 100) + '%';
        });
      }
      function frame(ts) {
        if (last === null) last = ts;
        const dt = ts - last; last = ts;
        if (!paused && !reduce) {
          elapsed += dt;
          if (elapsed >= DURATION) { elapsed = 0; active = (active + 1) % slides.length; }
          apply();
        }
        requestAnimationFrame(frame);
      }
      function goTo(n) { active = (n + slides.length) % slides.length; elapsed = 0; apply(); }

      dots.forEach((d, i) => d.addEventListener('click', () => goTo(i)));
      const prev = car.querySelector('.vc-prev');
      const next = car.querySelector('.vc-next');
      if (prev) prev.addEventListener('click', () => goTo(active - 1));
      if (next) next.addEventListener('click', () => goTo(active + 1));

      apply();
      requestAnimationFrame(frame);
    })();
  </script>


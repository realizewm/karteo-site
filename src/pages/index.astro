  <script>
    // ============ Utilidades de animação ============
    const reduz = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function fmt(n: number, dec: number): string {
      return n.toLocaleString('pt-BR', { minimumFractionDigits: dec, maximumFractionDigits: dec });
    }

    // Contador: anima o número de 0 até data-to (com prefixo/sufixo/decimais)
    function conta(el: HTMLElement) {
      const to = Number(el.dataset.to || 0);
      const dec = Number(el.dataset.dec || 0);
      const pre = el.dataset.pre || '';
      const suf = el.dataset.suf || '';
      if (reduz) { el.textContent = pre + fmt(to, dec) + suf; return; }
      const dur = Number(el.dataset.dur || 1300);
      const t0 = performance.now();
      function frame(t: number) {
        const p = Math.min(1, (t - t0) / dur);
        const e = 1 - Math.pow(1 - p, 3);
        el.textContent = pre + fmt(to * e, dec) + suf;
        if (p < 1) requestAnimationFrame(frame);
      }
      requestAnimationFrame(frame);
    }

    // (Re)dispara todas as animações de um widget: barras, fades, linhas e contadores
    function tocaWidget(card: HTMLElement) {
      card.classList.remove('play');
      void card.offsetWidth; // força reflow pra reiniciar transições
      card.classList.add('play');
      card.querySelectorAll<HTMLElement>('.cnt').forEach(conta);
    }

    // ============ Hero: o relatório ganha vida ao carregar ============
    const hero = document.getElementById('hero-report');
    if (hero) setTimeout(() => tocaWidget(hero), 350);

    // ============ Revelação por scroll ============
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('in');
            io.unobserve(e.target);
          }
        });
      },
      { threshold: 0.18 }
    );
    document.querySelectorAll('.rv').forEach((el) => io.observe(el));

    // ============ Explicador 360°: hover/clique + passeio automático de 5s ============
    const nos = document.querySelectorAll<HTMLElement>('[data-no]');
    const paineis = document.querySelectorAll<HTMLElement>('[data-painel]');
    const cometa = document.getElementById('cometa');
    const seletor = document.querySelector<HTMLElement>('.giro-sel');
    const N = paineis.length;
    const CICLO = 5000; // 5 segundos por dimensão
    let atual = 0;
    let visivel = false;
    let angCometa = 0;
    let passeio: ReturnType<typeof setInterval> | null = null;

    function ativar(i: number) {
      // o cometa sempre gira pra frente, acumulando voltas
      angCometa += (((i - atual) % N) + N) % N * 45;
      atual = i;
      if (cometa) cometa.style.transform = `rotate(${angCometa}deg)`;
      nos.forEach((n) => n.classList.toggle('ativo', Number(n.dataset.no) === i));
      paineis.forEach((p) => {
        const liga = Number(p.dataset.painel) === i;
        p.style.display = liga ? '' : 'none';
        if (liga) {
          // reinicia a entrada do painel + as animações do widget interno
          p.style.animation = 'none';
          void p.offsetWidth;
          p.style.animation = '';
          const card = p.querySelector<HTMLElement>('.wcard');
          if (card) tocaWidget(card);
        }
      });
    }

    function iniciaPasseio() {
      if (passeio || reduz || !visivel) return;
      seletor?.classList.add('auto');
      passeio = setInterval(() => ativar((atual + 1) % N), CICLO);
    }

    function pausaPasseio() {
      if (passeio) { clearInterval(passeio); passeio = null; }
      seletor?.classList.remove('auto');
    }

    nos.forEach((n) => {
      const i = Number(n.dataset.no);
      n.addEventListener('mouseenter', () => { pausaPasseio(); ativar(i); });
      n.addEventListener('click', () => { pausaPasseio(); ativar(i); });
      n.addEventListener('focus', () => { pausaPasseio(); ativar(i); });
    });

    // Cursor sobre a RODA → pausa; fora → retoma. Seção visível na tela → roda; fora → para.
    const giro = document.getElementById('giro360');
    const roda = seletor; // .giro-sel: só a roda, não o painel de texto à esquerda
    if (giro && roda) {
      roda.addEventListener('mouseenter', pausaPasseio);
      roda.addEventListener('mouseleave', iniciaPasseio);
      roda.addEventListener('focusout', (e) => {
        if (!roda.contains((e as FocusEvent).relatedTarget as Node)) iniciaPasseio();
      });
      const ioGiro = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            visivel = e.isIntersecting;
            if (visivel && !roda.matches(':hover')) iniciaPasseio();
            else if (!visivel) pausaPasseio();
          });
        },
        { threshold: 0.35 }
      );
      ioGiro.observe(giro);
    }

    ativar(0);

    // ============ Ponte: páginas espiando atrás da capa, uma de cada vez ============
    const esp = document.getElementById('espiar');
    if (esp && !reduz) {
      const espPags = esp.querySelectorAll<HTMLElement>('.esp-pag');
      let espVez = -1;
      let espCiclo: ReturnType<typeof setInterval> | null = null;

      function espProxima() {
        espVez = (espVez + 1) % espPags.length;
        espPags.forEach((p) => p.classList.toggle('viva', Number(p.dataset.esp) === espVez));
      }

      function espComeca() {
        if (!espCiclo) { espProxima(); espCiclo = setInterval(espProxima, 2400); }
      }

      function espPara() {
        if (espCiclo) { clearInterval(espCiclo); espCiclo = null; }
        espPags.forEach((p) => p.classList.remove('viva'));
        espVez = -1;
      }

      // cursor em cima → o hover manda (revezamento pausa); saiu → revezamento volta
      esp.addEventListener('mouseenter', espPara);
      esp.addEventListener('mouseleave', espComeca);
      const ioEsp = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting && !esp!.matches(':hover')) espComeca();
            else if (!e.isIntersecting) espPara();
          });
        },
        { threshold: 0.3 }
      );
      ioEsp.observe(esp);
    }

    // ============ Plano de ação: anima quando entra na tela ============
    const crm = document.getElementById('crm-card');
    if (crm) {
      const ioCrm = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) { tocaWidget(crm); ioCrm.unobserve(crm); }
          });
        },
        { threshold: 0.4 }
      );
      ioCrm.observe(crm);
    }

    // ============ Calculadora: economia reduzindo o churn em 30% ============
    const REDUCAO_CHURN = 0.3;
    const brlFmt = (n: number) => 'R$ ' + fmt(n, 0);
    const elPerdidos = document.getElementById('calc-perdidos') as HTMLInputElement | null;
    const elFee = document.getElementById('calc-fee') as HTMLInputElement | null;
    const elOut = document.getElementById('calc-out');
    let valorAtual = 7200;

    function parseNum(v: string): number {
      return Number(String(v).replace(/[^\d]/g, '')) || 0;
    }

    function animaSaida(novo: number) {
      if (!elOut) return;
      if (reduz) { elOut.textContent = brlFmt(novo); valorAtual = novo; return; }
      const de = valorAtual;
      valorAtual = novo;
      const t0 = performance.now();
      const dur = 550;
      function frame(t: number) {
        const p = Math.min(1, (t - t0) / dur);
        const e = 1 - Math.pow(1 - p, 3);
        elOut!.textContent = brlFmt(de + (novo - de) * e);
        if (p < 1 && valorAtual === novo) requestAnimationFrame(frame);
      }
      requestAnimationFrame(frame);
    }

    function recalc() {
      if (!elPerdidos || !elFee) return;
      animaSaida(Math.round(parseNum(elPerdidos.value) * parseNum(elFee.value) * REDUCAO_CHURN));
    }

    elPerdidos?.addEventListener('input', recalc);
    elFee?.addEventListener('input', recalc);
  </script>
</Layout>

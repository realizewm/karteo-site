---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';

// CTA principal: WhatsApp com mensagem pré-preenchida (decisão 15/07)
const wa = 'https://wa.me/5582981020001?text=Ol%C3%A1%2C%20Jo%C3%A3o!%20Quero%20agendar%20uma%20demonstra%C3%A7%C3%A3o%20do%20Karteo%20pro%20meu%20escrit%C3%B3rio.';

// As 8 dimensões da visão 360° — os painéis (com widgets animados) são escritos à mão abaixo.
const dims = [
  { n: '01', curto: 'Fluxo de caixa', nome: 'Fluxo de caixa',
    oque: 'Revela para onde o dinheiro do cliente realmente vai, e quanto sobra de verdade.',
    como: 'Você importa os extratos do cliente e o Karteo organiza receitas e despesas sozinho, calculando a capacidade real de poupança e a reserva de emergência ideal. Sem depender da memória do cliente.' },
  { n: '02', curto: 'Objetivos', nome: 'Objetivos de vida',
    oque: 'Transforma sonhos como imóvel, carro, educação e viagem em metas com prazo e valor.',
    como: 'Para cada objetivo, o Karteo calcula quanto poupar por mês e avisa na hora se a renda comporta tudo. Os conflitos aparecem antes de virarem frustração na reunião.' },
  { n: '03', curto: 'Aposentadoria', nome: 'Aposentadoria',
    oque: 'Responde a pergunta que todo cliente faz: quando, e com quanto, eu posso parar?',
    como: 'O Karteo projeta o patrimônio no tempo em três cenários, mostra o número que o cliente precisa atingir e o ritmo de aporte pra chegar lá, corrigido pela inflação real.' },
  { n: '04', curto: 'Patrimônio', nome: 'Patrimônio por inteiro',
    oque: 'Enxerga o patrimônio total do cliente: o que gera renda, o que só custa e o quanto está concentrado.',
    como: 'O Karteo soma as posições das corretoras ao patrimônio não financeiro (imóveis, participações) e mostra o total real, o que rende e o que só custa.' },
  { n: '05', curto: 'Proteção', nome: 'Proteção patrimonial',
    oque: 'Mostra, em número, se a família fica protegida caso algo aconteça com o cliente.',
    como: 'O Karteo dimensiona quanto os herdeiros precisariam e compara com os seguros atuais, apontando o gap de proteção em vez de deixar a conversa no achismo.' },
  { n: '06', curto: 'Tributário', nome: 'Planejamento tributário',
    oque: 'Identifica se o cliente paga mais imposto do que precisaria.',
    como: 'O Karteo simula estratégias como PGBL e mostra a economia fiscal possível: um argumento de valor concreto que talvez nem o contador do seu cliente ofereça.' },
  { n: '07', curto: 'Sucessão', nome: 'Sucessão',
    oque: 'Planeja como o patrimônio atravessa gerações com o menor custo e atrito.',
    como: 'Calcula o custo real de transmitir o patrimônio (ITCMD, cartório, honorários) e o capital que a família precisaria ter reservado para essa conta.' },
  { n: '08', curto: 'Alocação', nome: 'Recomendações e alocação final',
    oque: 'Fecha o plano com um destino claro pra cada real.',
    como: 'O Karteo consolida tudo numa alocação de recursos (reserva, objetivos e aposentadoria) com aporte inicial e mensal por destino. O cliente sai com um mapa, não com boas intenções.' },
];

// Posições em 360° ao redor do centro (começa no topo, 45° cada)
const R_CIRCULO = 40;
// Rótulo sempre pra FORA do círculo: topo sobe, laterais vão pro lado, base desce.
const ladoRotulo = (i: number) => (i === 2 ? 'dir' : i === 6 ? 'esq' : i >= 3 && i <= 5 ? 'baixo' : 'cima');
const dimsPos = dims.map((d, i) => {
  const ang = ((-90 + i * 45) * Math.PI) / 180;
  return { ...d, x: 50 + R_CIRCULO * Math.cos(ang), y: 50 + R_CIRCULO * Math.sin(ang), lado: ladoRotulo(i) };
});
---

<Layout
  title="Karteo para escritórios — gestão de carteira não é mais diferencial"
  description="A visão de 360° da vida financeira do cliente, em cerca de uma hora, com o método embutido. Para escritórios de consultoria e planejamento financeiro."
>
  <!-- NAVBAR -->
  <header class="sticky top-0 z-40 border-b border-border-soft/60 bg-surface/80 backdrop-blur">
    <nav class="mx-auto flex max-w-[1320px] items-center justify-between px-6 py-4">
      <a href="/" class="flex items-center gap-2">
        <span class="logo-wordmark text-xl text-dark">karteo<span class="logo-dot">.</span></span>
      </a>
      <div class="hidden items-center gap-8 md:flex">
        <a href="#virada" class="text-sm text-subtle transition hover:text-body">Por que agora</a>
        <a href="#prova" class="text-sm text-subtle transition hover:text-body">O relatório</a>
        <a href="#como-funciona" class="text-sm text-subtle transition hover:text-body">Como funciona</a>
      </div>
      <a href="#cta" class="rounded-lg bg-teal px-4 py-2 text-sm font-semibold text-white transition hover:bg-teal-hover">
        Agendar demonstração
      </a>
    </nav>
  </header>

  <!-- 1 · HERO — dark editorial, com o gráfico do relatório ganhando vida -->
  <section class="relative overflow-hidden bg-dark">
    <div class="absolute inset-0 z-0 bg-[radial-gradient(circle_at_72%_18%,rgba(20,184,166,0.20),transparent_45%),radial-gradient(circle_at_8%_92%,rgba(99,102,241,0.14),transparent_42%)]"></div>
    <div class="absolute inset-x-0 top-0 z-0 h-px bg-gradient-to-r from-transparent via-teal-light/40 to-transparent"></div>
    <div class="relative z-10 mx-auto grid max-w-[1320px] items-center gap-12 px-6 py-24 lg:grid-cols-[1.1fr_0.95fr] lg:gap-16 lg:py-28">
      <div>
        <h1 class="text-[44px] font-bold leading-[1.04] tracking-tight text-white md:text-[62px]">
          Gestão de carteira virou <span class="text-teal-light">commodity</span>.
        </h1>
        <p class="mt-6 max-w-xl text-2xl font-semibold leading-snug text-white/85 md:text-[30px]">
          O que segura o cliente não mora na carteira. Mora no planejamento.
        </p>
        <p class="mt-6 max-w-md text-lg leading-relaxed text-white/55">
          E é isso que o Karteo põe na sua mão: a vida financeira do cliente por inteiro, com a sua marca, em cerca de uma hora.
        </p>
        <div class="mt-9">
          <a href="#cta" class="inline-block rounded-lg bg-teal px-7 py-4 text-sm font-semibold text-white shadow-[0_16px_40px_-12px_rgba(13,148,136,0.7)] transition hover:bg-teal-light">
            Agendar demonstração
          </a>
        </div>
      </div>

      <!-- Cenário de aposentadoria animado — números de um plano real -->
      <div class="relative">
        <div class="absolute -inset-6 z-0 rounded-[2rem] bg-teal-light/20 blur-3xl"></div>
        <div id="hero-report" class="wcard relative z-10">
          <div class="whead">
            <span class="wnum">7</span>
            <div>
              <div class="wtitle">Cenário de Aposentadoria</div>
              <div class="wsub">Aos 65 anos · renda desejada R$ 50.000/mês</div>
            </div>
            <span class="wbrand">KARTEO</span>
          </div>
          <div class="wbody">
            <div class="wlegend">
              <span class="wleg"><i style="background:#0D9488"></i>Sua projeção</span>
              <span class="wleg"><i style="background:#6366F1"></i>Viver de renda</span>
              <span class="wleg"><i style="background:#94A3B8"></i>Consumir patrimônio</span>
            </div>
            <svg viewBox="0 0 560 300" class="mt-3 w-full" aria-label="Projeção do patrimônio dos 36 aos 90 anos, em três cenários">
              <defs>
                <linearGradient id="hero-area" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0%" stop-color="#0D9488" stop-opacity="0.28" />
                  <stop offset="100%" stop-color="#0D9488" stop-opacity="0" />
                </linearGradient>
              </defs>
              <!-- grid -->
              <g stroke="#E5E7EB" stroke-width="1">
                <line x1="44" y1="64" x2="544" y2="64" /><line x1="44" y1="133" x2="544" y2="133" />
                <line x1="44" y1="203" x2="544" y2="203" /><line x1="44" y1="272" x2="544" y2="272" />
              </g>
              <g fill="#9CA3AF" font-size="11">
                <text x="8" y="68">R$ 15M</text><text x="8" y="137">R$ 10M</text>
                <text x="14" y="207">R$ 5M</text><text x="14" y="276">R$ 0</text>
                <text x="40" y="292">36</text><text x="166" y="292">50</text>
                <text x="305" y="292">65</text><text x="532" y="292">90</text>
              </g>
              <!-- área sob a projeção -->
              <path class="area" fill="url(#hero-area)"
                d="M44,262 C130,252 220,200 268,150 C295,122 305,98 312,82 L312,272 L44,272 Z" />
              <!-- marcador da aposentadoria -->
              <g class="mk">
                <line x1="312" y1="56" x2="312" y2="272" stroke="#0D9488" stroke-width="1" stroke-dasharray="3 4" stroke-opacity="0.5" />
                <rect x="256" y="40" width="112" height="20" rx="10" fill="#1A1A2E" />
                <text x="312" y="54" text-anchor="middle" fill="#5EEAD4" font-size="11" font-weight="600">aposentadoria</text>
                <circle class="dotp" cx="312" cy="82" r="4.5" fill="#0D9488" />
              </g>
              <!-- consumir patrimônio -->
              <path class="ln l3" fill="none" stroke="#94A3B8" stroke-width="2" stroke-dasharray="1400" stroke-linecap="round"
                d="M44,264 C140,256 240,205 312,149 C400,172 490,225 544,266" style="stroke-dasharray:5 6" />
              <!-- viver de renda -->
              <path class="ln l2" fill="none" stroke="#6366F1" stroke-width="2" stroke-linecap="round"
                d="M44,263 C135,254 235,180 312,94 L544,94" />
              <!-- sua projeção -->
              <path class="ln l1" fill="none" stroke="#0D9488" stroke-width="3" stroke-linecap="round"
                d="M44,262 C130,252 220,200 268,150 C295,122 305,98 312,82 C390,72 480,66 544,62" />
            </svg>
            <div class="mt-4 grid gap-3 sm:grid-cols-2">
              <div class="wkpi">
                <div class="wkpi-lab">Patrimônio projetado aos 65</div>
                <div class="wkpi-val cnt" data-to="13757389" data-pre="R$ ">R$ 13.757.389</div>
              </div>
              <div class="wkpi">
                <div class="wkpi-lab">Renda possível na aposentadoria</div>
                <div class="wkpi-val cnt" data-to="53436" data-pre="R$ " data-suf="/mês">R$ 53.436/mês</div>
              </div>
            </div>
            <div class="chip-ok fade" style="--d:1.4s">
              <Icon name="check" class="h-4 w-4 flex-none" />
              Projeção atende à renda desejada
            </div>
          </div>
        </div>
        <div class="absolute -bottom-3 left-1/2 z-20 -translate-x-1/2 whitespace-nowrap rounded-full border border-teal-light/30 bg-dark px-4 py-1.5 text-xs font-semibold text-teal-light shadow-[0_10px_30px_-10px_rgba(0,0,0,0.8)]">
          Números de um plano real feito no Karteo
        </div>
      </div>
    </div>
  </section>

  <!-- 1b · A PROVA (pesquisa Cerulli) -->
  <section id="prova-cliente" class="border-t border-border-soft bg-surface py-24 md:py-32">
    <div class="mx-auto max-w-[1160px] px-6">
      <div class="grid gap-12 md:grid-cols-[0.9fr_1.1fr] md:items-center md:gap-16">

        <!-- texto -->
        <div class="rv">
          <div class="flex items-baseline gap-5 md:gap-7">
            <span class="select-none text-5xl font-bold leading-none tracking-tight text-teal/25 tabular-nums md:text-7xl">01</span>
            <h2 class="max-w-[15ch] text-3xl font-bold leading-[1.08] tracking-tight text-dark md:text-[2.6rem]">
              Ninguém escolhe um assessor pela rentabilidade.
            </h2>
          </div>
          <p class="mt-6 max-w-[44ch] text-lg leading-relaxed text-subtle">
            No mercado mais maduro do mundo, os próprios investidores já disseram o que pesa na hora de confiar o patrimônio a alguém. E a performance não lidera.
          </p>
        </div>

        <!-- gráfico de barras -->
        <div id="cerulli-chart" class="rv flex flex-col gap-6">
          <p class="text-[13px] font-medium leading-snug text-subtle">% de investidores que consideram cada fator ao escolher um assessor</p>
          <div class="cerulli-row">
            <div class="mb-2 flex items-baseline justify-between gap-4">
              <span class="text-[15px] font-medium text-body">Entende meus objetivos e meu apetite a risco</span>
              <span class="text-lg font-bold tabular-nums text-teal">55%</span>
            </div>
            <div class="h-2.5 w-full overflow-hidden rounded-full bg-border-soft">
              <div class="cerulli-fill h-full rounded-full bg-teal transition-[width] duration-[1200ms] ease-out" style="width:0" data-value="55"></div>
            </div>
          </div>

          <div class="cerulli-row">
            <div class="mb-2 flex items-baseline justify-between gap-4">
              <span class="text-[15px] font-medium text-body">Enxerga meu quadro financeiro por inteiro</span>
              <span class="text-lg font-bold tabular-nums text-teal">49%</span>
            </div>
            <div class="h-2.5 w-full overflow-hidden rounded-full bg-border-soft">
              <div class="cerulli-fill h-full rounded-full bg-teal transition-[width] duration-[1200ms] ease-out" style="width:0" data-value="49"></div>
            </div>
          </div>

          <div class="cerulli-row">
            <div class="mb-2 flex items-baseline justify-between gap-4">
              <span class="text-[15px] font-medium text-subtle">Performance dos investimentos vs. mercado</span>
              <span class="text-lg font-bold tabular-nums text-slate-soft">46%</span>
            </div>
            <div class="h-2.5 w-full overflow-hidden rounded-full bg-border-soft">
              <div class="cerulli-fill h-full rounded-full bg-slate-soft transition-[width] duration-[1200ms] ease-out" style="width:0" data-value="46"></div>
            </div>
          </div>

          <p class="mt-1 text-xs leading-relaxed text-muted">
            Fonte: Cerulli Associates · investidores dos EUA · out/2024. Cada pessoa pôde marcar mais de um fator, por isso os valores não somam 100%.
          </p>
        </div>
      </div>

      <!-- remate -->
      <p class="rv mt-14 max-w-[58ch] border-l-2 border-dark/70 pl-5 text-xl font-semibold leading-relaxed text-body md:mt-16 md:text-2xl">
        A rentabilidade virou o mínimo. O que o cliente procura é <span class="text-teal">alguém que entenda a vida dele por inteiro</span>.
      </p>
    </div>
  </section>

  <script>
    (function () {
      const chart = document.getElementById('cerulli-chart');
      if (!chart) return;
      const fills = chart.querySelectorAll('.cerulli-fill');
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            // uma barra de cada vez (efeito "votos" carregando em sequência)
            fills.forEach((f, i) => { setTimeout(() => { f.style.width = f.dataset.value + '%'; }, i * 280); });
            io.disconnect();
          }
        });
      }, { threshold: 0.4 });
      io.observe(chart);
    })();
  </script>

  <!-- 3 · A VIRADA -->
  <section id="virada" class="border-t border-border-soft bg-bg-page pb-24 md:pb-32">
    <!-- conjunto: faixa (título, off-white) + carrossel (fotos grandes, full-bleed) -->
    <div class="relative left-1/2 w-screen -translate-x-1/2">

      <!-- faixa: título da dobra, sobre o off-white -->
      <div class="rv mx-auto max-w-[1160px] px-6 pb-8 pt-16 md:pb-10 md:pt-20">
        <div class="flex items-baseline gap-4 md:gap-7">
          <span class="select-none text-5xl font-bold leading-none tracking-tight text-teal/25 tabular-nums md:text-7xl">02</span>
          <h2 class="text-3xl font-bold leading-[1.1] tracking-tight text-dark md:text-[2.6rem]">
            Você entrega rentabilidade. Mas o seu cliente ainda espera pelas <span class="text-teal">respostas que a carteira não dá.</span>
          </h2>
        </div>
      </div>

      <!-- carrossel: fotos grandes (aspect 7:4), full-bleed -->
      <div id="virada-carousel" class="rv relative aspect-[7/4] max-h-[86vh] w-full overflow-hidden bg-dark" aria-roledescription="carrossel" aria-label="As respostas que a carteira não dá">

      <!-- 1 · aposentadoria — gente espalhada; o único respiro é o alto à direita (árvores) -->
      <figure class="vc-slide absolute inset-0 opacity-100 transition-opacity duration-[600ms] ease-out" data-idx="0">
        <img src="/images/virada/aposentadoria.jpg" alt="Casal grisalho cheio de energia correndo com os netos no quintal" class="vc-img h-full w-full object-cover object-center" />
        <div class="absolute inset-0 bg-gradient-to-bl from-black/70 via-black/10 to-transparent"></div>
        <figcaption class="absolute inset-0">
          <div class="mx-auto flex h-full max-w-[1160px] items-start justify-end px-6 pt-8 md:pt-12">
            <p class="max-w-[15ch] text-right text-2xl font-bold leading-tight tracking-tight text-white drop-shadow-[0_2px_16px_rgba(0,0,0,0.55)] md:text-[2.5rem]">“Posso me aposentar quando eu sonho, e com quanto por mês?”</p>
          </div>
        </figcaption>
      </figure>

      <!-- 2 · viagem — família à esquerda, texto embaixo à direita -->
      <figure class="vc-slide absolute inset-0 opacity-0 transition-opacity duration-[600ms] ease-out" data-idx="1">
        <img src="/images/virada/viagem.jpg" alt="Família jovem viajando junta, explorando uma cidade ensolarada" class="vc-img h-full w-full object-cover object-center" />
        <div class="absolute inset-0 bg-gradient-to-tl from-black/70 via-black/15 to-transparent"></div>
        <figcaption class="absolute inset-0">
          <div class="mx-auto flex h-full max-w-[1160px] items-end justify-end px-6 pb-16 md:pb-24">
            <p class="max-w-[16ch] text-right text-2xl font-bold leading-tight tracking-tight text-white drop-shadow-[0_2px_16px_rgba(0,0,0,0.55)] md:text-[2.5rem]">“Consigo fazer a viagem dos sonhos sem comprometer o resto?”</p>
          </div>
        </figcaption>
      </figure>

      <!-- 3 · transição — ela olha pra direita, texto embaixo à esquerda (sobre o balcão) -->
      <figure class="vc-slide absolute inset-0 opacity-0 transition-opacity duration-[600ms] ease-out" data-idx="2">
        <img src="/images/virada/transicao.jpg" alt="Empreendedora feliz no próprio café recém-aberto" class="vc-img h-full w-full object-cover object-center" />
        <div class="absolute inset-0 bg-gradient-to-tr from-black/70 via-black/15 to-transparent"></div>
        <figcaption class="absolute inset-0">
          <div class="mx-auto flex h-full max-w-[1160px] items-end justify-start px-6 pb-16 md:pb-24">
            <p class="max-w-[15ch] text-2xl font-bold leading-tight tracking-tight text-white drop-shadow-[0_2px_16px_rgba(0,0,0,0.55)] md:text-[2.5rem]">“Eu consigo fazer uma transição de carreira tranquila?”</p>
          </div>
        </figcaption>
      </figure>

      <!-- 4 · proteção — jovem+retrato à esquerda, texto embaixo à direita -->
      <figure class="vc-slide absolute inset-0 opacity-0 transition-opacity duration-[600ms] ease-out" data-idx="3">
        <img src="/images/virada/protecao.jpg" alt="Jovem na formatura segurando o porta-retrato do pai" class="vc-img h-full w-full object-cover object-center" />
        <div class="absolute inset-0 bg-gradient-to-tl from-black/70 via-black/15 to-transparent"></div>
        <figcaption class="absolute inset-0">
          <div class="mx-auto flex h-full max-w-[1160px] items-end justify-end px-6 pb-16 md:pb-24">
            <p class="max-w-[15ch] text-right text-2xl font-bold leading-tight tracking-tight text-white drop-shadow-[0_2px_16px_rgba(0,0,0,0.55)] md:text-[2.5rem]">“Minha família fica protegida se algo acontecer comigo?”</p>
          </div>
        </figcaption>
      </figure>

      <!-- setas de navegação manual -->
      <button type="button" class="vc-prev absolute left-3 top-1/2 z-20 grid h-11 w-11 -translate-y-1/2 place-items-center rounded-full bg-black/25 text-white backdrop-blur-sm transition hover:bg-black/45 md:left-6" aria-label="Pergunta anterior">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
      <button type="button" class="vc-next absolute right-3 top-1/2 z-20 grid h-11 w-11 -translate-y-1/2 place-items-center rounded-full bg-black/25 text-white backdrop-blur-sm transition hover:bg-black/45 md:right-6" aria-label="Próxima pergunta">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
      </button>

      <!-- indicador: barras que enchem, sinalizando a troca -->
      <div class="absolute inset-x-0 bottom-0 z-10">
        <div class="mx-auto flex max-w-[1160px] gap-2 px-6 pb-6">
          <button type="button" class="vc-dot relative h-1 flex-1 overflow-hidden rounded-full bg-white/25" data-idx="0" aria-label="Pergunta 1"><span class="vc-fill absolute inset-y-0 left-0 block w-0 bg-white"></span></button>
          <button type="button" class="vc-dot relative h-1 flex-1 overflow-hidden rounded-full bg-white/25" data-idx="1" aria-label="Pergunta 2"><span class="vc-fill absolute inset-y-0 left-0 block w-0 bg-white"></span></button>
          <button type="button" class="vc-dot relative h-1 flex-1 overflow-hidden rounded-full bg-white/25" data-idx="2" aria-label="Pergunta 3"><span class="vc-fill absolute inset-y-0 left-0 block w-0 bg-white"></span></button>
          <button type="button" class="vc-dot relative h-1 flex-1 overflow-hidden rounded-full bg-white/25" data-idx="3" aria-label="Pergunta 4"><span class="vc-fill absolute inset-y-0 left-0 block w-0 bg-white"></span></button>
        </div>
      </div>
    </div>
    </div>

    <!-- ponte pra a segunda metade — virada de ato -->
    <div class="mx-auto max-w-[1160px] px-6">
      <div class="rv mx-auto mt-20 max-w-[40ch] text-center md:mt-28">
        <div class="mx-auto mb-7 h-px w-12 bg-teal/40"></div>
        <p class="text-3xl font-bold leading-tight tracking-tight text-dark md:text-5xl">
          É por isso que existe o <span class="text-teal">Karteo</span>.
        </p>
        <p class="mx-auto mt-5 max-w-[42ch] text-lg leading-relaxed text-subtle">
          A ferramenta que transforma cada uma dessas perguntas num plano de verdade, com a sua marca.
